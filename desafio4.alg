algoritmo "Simulador de inventário"

var

item:caractere




inicio

escreva("Digite o nome do primeiro item que chegou: ")
leia(item)
escreval("Item registrado: " + item)
escreval("Digite o nome do segundo item que chegou: ")
leia(item)
escreva("Item 1 descartado. Item 2 registrado: " + item)

fimalgoritmo